!!! html

%html
  %head
    %meta(charset="UTF-8")
    %meta(name="viewport" content="width=device-width, initial-scale=1.0")
    %link(rel="stylesheet" type="text/css" href="/css/main.css")
    %link(rel="stylesheet" type="text/css" href="/css/code.css")
    %script(type="text/javascript" src="//cdnjs.cloudflare.com/ajax/libs/jquery/1.7.1/jquery.min.js")
    %script(type='text/javascript' src='https://storage.ko-fi.com/cdn/widget/Widget_2.js')
    %script(type="text/javascript" src="/js/application.js")

    - title Site[:title]
    %title= title.join(' | ')
    %meta{name: 'description', content: description}

  %body
    #container
      %h1
        %a(href="/")= Site[:title]
      %nav
        %menu
          - Links.each do |link|
            %li
              - if link.target
                %a{href:link.href, target:link.target}= link.name
              - else
                %a{href:link.href}= link.name
          %li.ko-fi
            :javascript
              kofiwidget2.init('Support my art', '#72a4f2', 'M4M3KG4QU')
              kofiwidget2.draw();
      %section= yield

      %footer
        All content &copy; #{Site[:author]}.
        If you'd like to copy, remix, or redistribute this work, please
        %a(href="/pages/about") contact me.
